apiVersion: metallb.io/v1beta1
kind: IPAddressPool
metadata:
  name: {{ metallb_pool_name }}
  namespace: {{ metallb_namespace }}
spec:
  addresses:
{% for address in metallb_addresses %}
    - {{ address }}
{% endfor %}
---
apiVersion: metallb.io/v1beta1
kind: L2Advertisement
metadata:
  name: {{ metallb_l2_advertisement_name }}
  namespace: {{ metallb_namespace }}
spec:
  ipAddressPools:
    - {{ metallb_pool_name }}
